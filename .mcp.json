{
  "mcpServers": {
    "lpc": {
      "command": "node",
      "args": ["/projects/git/lpc-mcp/src/index.js"],
      "env": {
        "LPC_WORKSPACE_ROOT": "/mud/ox/lib"
      }
    },
    "FluffOS": {
      "command": "node",
      "args": ["/projects/git/fluffos-mcp/src/index.js"],
      "env": {
        "FLUFFOS_BIN_DIR": "/mud/ox/bin",
        "MUD_RUNTIME_CONFIG_FILE": "/mud/ox/bin/config.oxidus",
        "FLUFFOS_DOCS_DIR": "/mud/ox/fluffos/docs"
      }
    }
  }
}
